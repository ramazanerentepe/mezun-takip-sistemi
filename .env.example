# --- Veritabanı Docker Ayarları ---
# Docker konteyneri için kullanıcı adı (Varsayılan: admin)
POSTGRES_USER=admin

# Docker konteyneri için veritabanı şifresi (Burası kullanıcı tarafından değiştirilmelidir)
POSTGRES_PASSWORD=sifreniz_buraya

# Oluşturulacak veritabanının adı
POSTGRES_DB=mezun_takip
