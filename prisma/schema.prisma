// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// GEÇİCİ TEST TABLOSU (Daha sonra sileceğiz)
model TestTable {
  id           Int      @id @default(autoincrement())
  denemeVerisi String
  createdAt    DateTime @default(now())
}
